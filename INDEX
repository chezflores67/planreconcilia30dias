<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Juntos de Nuevo — Plan de 30 Días</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --coral: #E8567A; --coral-light: #FFF0F3;
            --gold: #F5A623; --gold-light: #FFFAEE;
            --sage: #5BAD8F; --sage-light: #F0FAF5;
            --violet: #9B72CF; --violet-light: #F5F0FF;
            --cream: #FFF6EE; --white: #FFFFFF;
            --ink: #2D1B1B; --ink-soft: #5C3D3D;
        }

        body {
            background-color: var(--cream);
            color: var(--ink);
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 20px;
            line-height: 1.6;
        }

        .container { max-width: 800px; margin: 0 auto; }

        header { text-align: center; margin-bottom: 40px; padding: 40px 20px; }
        h1 { font-family: 'Playfair Display', serif; color: var(--coral); font-size: 2.5rem; margin-bottom: 10px; }
        .subtitle { font-style: italic; color: var(--ink-soft); font-size: 1.1rem; }

        .week-section { margin-bottom: 50px; }
        .week-header { 
            display: flex; align-items: center; gap: 15px;
            padding: 15px; border-radius: 12px; margin-bottom: 20px;
        }

        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 15px; }

        .day-card {
            background: var(--white);
            padding: 20px;
            border-radius: 15px;
            text-align: center;
            cursor: pointer;
            transition: transform 0.2s;
            border: 2px solid transparent;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }
        .day-card:hover { transform: translateY(-5px); border-color: var(--coral); }
        .day-card .icon { font-size: 24px; margin-bottom: 8px; }
        .day-card .label { font-weight: 600; font-size: 0.9rem; }

        /* Modal / Detalle */
        #detail-view {
            display: none;
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(45, 27, 27, 0.9);
            z-index: 1000; align-items: center; justify-content: center; padding: 20px;
        }
        .modal-content {
            background: var(--white);
            max-width: 600px; width: 100%;
            padding: 40px; border-radius: 24px;
            position: relative;
        }
        .close-btn { position: absolute; top: 20px; right: 20px; font-size: 24px; cursor: pointer; border: none; background: none; }
        
        .tag { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: bold; margin-bottom: 15px; }
        .task-box { background: var(--coral-light); padding: 20px; border-radius: 15px; border-left: 5px solid var(--coral); margin: 20px 0; }
        .quote { font-style: italic; color: var(--ink-soft); text-align: center; margin: 20px 0; }
        .tip-box { font-size: 0.9rem; color: var(--sage); border-top: 1px solid #eee; pt: 15px; }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h1>💑 Juntos de Nuevo</h1>
        <p class="subtitle">30 días para reconstruir lo que importa</p>
    </header>

    <div id="plan-container"></div>
</div>

<div id="detail-view">
    <div class="modal-content" id="modal-body">
        </div>
</div>

<script>
    const weekMeta = {
        1: { label: "Reconocimiento", color: "#E8567A", bg: "#FFF0F3", emoji: "👁️", tagline: "Ver con honestidad para avanzar" },
        2: { label: "Reconexión", color: "#F5A623", bg: "#FFFAEE", emoji: "🤝", tagline: "Conocerse otra vez" },
        3: { label: "Intimidad", color: "#9B72CF", bg: "#F5F0FF", emoji: "🌸", tagline: "El perdón y el contacto" },
        4: { label: "Compromiso", color: "#5BAD8F", bg: "#F0FAF5", emoji: "🌿", tagline: "Construir la nueva versión" }
    };

    // Datos extraídos del JSX original
    const days = [
        { day: 1, week: 1, title: "El Primer Gesto", icon: "👁️", task: "Esta noche, sin teléfono, siéntense frente a frente 5 minutos. Solo mírense a los ojos. Al terminar, digan una palabra de lo que sintieron.", reflection: "El amor no se fue. Se cubrió de costumbre.", tip: "Apaga notificaciones desde las 9 PM." },
        { day: 2, week: 1, title: "La Pregunta Real", icon: "💬", task: "Pregunta genuinamente: '¿Cómo estás tú... de verdad?' Escucha sin juzgar ni aconsejar.", reflection: "Escuchar es el primer acto de amor que olvidamos.", tip: "No interrumpas. Solo recibe." },
        { day: 3, week: 1, title: "La Carta Silenciosa", icon: "✍️", task: "Escribe 3 momentos donde elegiste la distancia. No acuses, solo confiesa lo tuyo.", reflection: "Lo que se nombra puede ser cambiado.", tip: "Usa papel y pluma, es más íntimo." },
        // ... Se pueden agregar los 30 días aquí siguiendo este patrón
        { day: 30, week: 4, title: "Lo Lograron", icon: "🌄", task: "Elijan 3 prácticas permanentes y escríbanlas como su nuevo Código de Pareja.", reflection: "30 días no arreglan todo, pero son el inicio de una nueva historia.", tip: "Celebren hoy su valentía." }
    ];

    const planContainer = document.getElementById('plan-container');

    // Renderizar Semanas
    for (let w = 1; w <= 4; w++) {
        const meta = weekMeta[w];
        const weekHtml = `
            <section class="week-section">
                <div class="week-header" style="background:${meta.bg}; color:${meta.color}">
                    <span style="font-size: 2rem">${meta.emoji}</span>
                    <div>
                        <strong style="display:block">Semana ${w}: ${meta.label}</strong>
                        <small>${meta.tagline}</small>
                    </div>
                </div>
                <div class="grid" id="week-${w}-grid"></div>
            </section>
        `;
        planContainer.innerHTML += weekHtml;
    }

    // Renderizar Días
    days.forEach(d => {
        const grid = document.getElementById(`week-${d.week}-grid`);
        const card = document.createElement('div');
        card.className = 'day-card';
        card.innerHTML = `<div class="icon">${d.icon}</div><div class="label">Día ${d.day}</div>`;
        card.onclick = () => showDetail(d);
        grid.appendChild(card);
    });

    function showDetail(d) {
        const meta = weekMeta[d.week];
        const modalBody = document.getElementById('modal-body');
        modalBody.innerHTML = `
            <button class="close-btn" onclick="closeModal()">&times;</button>
            <span class="tag" style="background:${meta.bg}; color:${meta.color}">DÍA ${d.day} — ${meta.label.toUpperCase()}</span>
            <h2 style="font-family:'Playfair Display'; margin-top:0">${d.title}</h2>
            <div class="task-box" style="border-color:${meta.color}; background:${meta.bg}">
                <strong>El Reto:</strong><br>${d.task}
            </div>
            <p class="quote">"${d.reflection}"</p>
            <div class="tip-box">
                <strong>💡 Consejo:</strong> ${d.tip}
            </div>
        `;
        document.getElementById('detail-view').style.display = 'flex';
    }

    function closeModal() {
        document.getElementById('detail-view').style.display = 'none';
    }
</script>

</body>
</html>
